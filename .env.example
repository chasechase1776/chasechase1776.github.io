# Database
# Use SQLite for the local MVP. Keep the real database file out of Git.
DATABASE_URL="file:./data/app.db"

# Public app URL and runtime mode
APP_BASE_URL="http://localhost:3000"
NODE_ENV="development"

# AI parsing is optional. The app must still support manual logging without this.
OPENAI_API_KEY=""
AI_PARSER_MODE="disabled"

# Local evidence/file storage
# Keep uploaded homeschool records, photos, scans, videos, and generated exports out of Git.
APP_STORAGE_PATH="./storage"
STORAGE_PROVIDER="local"
LOCAL_UPLOAD_DIR="./storage/evidence"

# Pre-launch / trial mode
OFFICIAL_HOMESCHOOL_START_DATE="2027-05-01"
INCLUDE_TRIAL_RECORDS_IN_REPORTS="false"

# App security
# Generate a strong value before enabling authentication/session features.
APP_SECRET=""

# Future cloud storage, if enabled later
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_REGION=""
